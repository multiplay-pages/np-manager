{
  "name": "np-manager",
  "version": "1.0.0",
  "private": true,
  "description": "System zarządzania przenoszeniem numerów stacjonarnych (NP-Manager)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently --names \"backend,frontend\" --prefix-colors \"blue,green\" \"npm run dev -w apps/backend\" \"npm run dev -w apps/frontend\"",
    "dev:backend": "npm run dev -w apps/backend",
    "dev:frontend": "npm run dev -w apps/frontend",
    "build": "npm run build -w packages/shared && npm run build -w apps/backend && npm run build -w apps/frontend",
    "build:shared": "npm run build -w packages/shared",
    "lint": "eslint \"apps/**/*.{ts,tsx}\" \"packages/**/*.ts\" --ignore-pattern \"**/dist/**\" --ignore-pattern \"**/node_modules/**\"",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier --write \"apps/**/*.{ts,tsx,json}\" \"packages/**/*.{ts,json}\"",
    "format:check": "prettier --check \"apps/**/*.{ts,tsx,json}\" \"packages/**/*.{ts,json}\"",
    "test": "npm run test -w packages/shared && npm run test -w apps/backend",
    "db:generate": "npm run db:generate -w apps/backend",
    "db:migrate": "npm run db:migrate -w apps/backend",
    "db:migrate:prod": "npm run db:migrate:prod -w apps/backend",
    "db:seed": "npm run db:seed -w apps/backend",
    "db:studio": "npm run db:studio -w apps/backend",
    "db:reset": "npm run db:reset -w apps/backend"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "concurrently": "^9.0.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
