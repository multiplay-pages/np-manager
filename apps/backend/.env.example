# ============================================================
# BAZA DANYCH
# ============================================================
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://np_user:np_password@localhost:5432/np_manager"

# ============================================================
# AUTORYZACJA JWT
# ============================================================
# Min. 32 losowe znaki - wygeneruj np.: openssl rand -hex 32
JWT_SECRET="ZMIEN_NA_LOSOWY_STRING_MIN_32_ZNAKI_PRZED_WDROZENIEM"
JWT_EXPIRES_IN="8h"

# ============================================================
# APLIKACJA
# ============================================================
PORT=3001
NODE_ENV="development"
FRONTEND_URL="http://localhost:5173"

# ============================================================
# PRZECHOWYWANIE PLIKOW
# ============================================================
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=10

# ============================================================
# LOGOWANIE
# ============================================================
LOG_LEVEL="info"

# ============================================================
# PLI CBD REAL_SOAP (placeholder pod przyszly adapter)
# ============================================================
PLI_CBD_TRANSPORT_MODE="STUB"
PLI_CBD_REAL_SOAP_ENDPOINT_URL=""
PLI_CBD_REAL_SOAP_CONNECT_TIMEOUT_MS=5000
PLI_CBD_REAL_SOAP_REQUEST_TIMEOUT_MS=20000
PLI_CBD_REAL_SOAP_CLIENT_CERTIFICATE_PATH=""
PLI_CBD_REAL_SOAP_CLIENT_CERTIFICATE_ALIAS=""
PLI_CBD_REAL_SOAP_CLIENT_KEY_PATH=""
PLI_CBD_REAL_SOAP_CA_CERTIFICATE_PATH=""
PLI_CBD_REAL_SOAP_ENVIRONMENT_NAME="LOCAL"
PLI_CBD_REAL_SOAP_PROFILE="LOCAL_DEFAULT"
PLI_CBD_REAL_SOAP_ACTION_E03="urn:pli-cbd:fnp:E03"
PLI_CBD_REAL_SOAP_ACTION_E12="urn:pli-cbd:fnp:E12"
PLI_CBD_REAL_SOAP_ACTION_E18="urn:pli-cbd:fnp:E18"
PLI_CBD_REAL_SOAP_ACTION_E23="urn:pli-cbd:fnp:E23"

# ============================================================
# POWIADOMIENIA WEWNETRZNE — transport email (PR13B)
# ============================================================
# Tryb adaptera email dla notyfikacji wewnetrznych:
#   STUB     — brak realnej wysylki, loguje stub (domyslnie)
#   REAL     — wysylka przez SMTP (wymaga konfiguracji ponizej)
#   DISABLED — transport cakowicie wylaczony
INTERNAL_NOTIFICATION_EMAIL_ADAPTER="STUB"

# ============================================================
# SMTP — konfiguracja serwera poczty wychodzącej
# Wymagane gdy INTERNAL_NOTIFICATION_EMAIL_ADAPTER=REAL
# ============================================================
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@np-manager.local"
