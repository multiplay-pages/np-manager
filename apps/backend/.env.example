# ============================================================
# BAZA DANYCH
# ============================================================
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://np_user:np_password@localhost:5432/np_manager"

# ============================================================
# AUTORYZACJA JWT
# ============================================================
# Min. 32 losowe znaki — wygeneruj np.: openssl rand -hex 32
JWT_SECRET="ZMIEN_NA_LOSOWY_STRING_MIN_32_ZNAKI_PRZED_WDROZENIEM"
JWT_EXPIRES_IN="8h"

# ============================================================
# APLIKACJA
# ============================================================
PORT=3001
NODE_ENV="development"
# Adres frontendu (używany do konfiguracji CORS)
FRONTEND_URL="http://localhost:5173"

# ============================================================
# PRZECHOWYWANIE PLIKÓW
# ============================================================
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=10

# ============================================================
# LOGOWANIE
# ============================================================
# Poziomy: debug | info | warn | error
LOG_LEVEL="info"

# ============================================================
# EMAIL (Faza 2 — na razie pozostaw puste)
# ============================================================
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@np-manager.local"
